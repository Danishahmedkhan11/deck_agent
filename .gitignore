# ── Secrets & credentials (NEVER commit) ──────────────────────────────────
.env
.env.*
!.env.example
**/*service-account*.json
backend/my-first-project-org-*.json
*-org-*.json
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/

# ── Runtime artifacts ─────────────────────────────────────────────────────
backend/uploads/
*.pptx
!backend/template/*.pptx
*.spec.json
*.meta.json

# ── Archives (stale zipped copies — real source is tracked directly) ───────
*.7z
*.zip

# ── OS / editor ───────────────────────────────────────────────────────────
.DS_Store
*.swp
.idea/
.vscode/
